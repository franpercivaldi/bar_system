# Copiar a .env (no commitear .env con secretos reales)

# Opción A: desarrollo local con Postgres en Docker o local
DB_HOST=localhost
DB_PORT=5432
DB_USER=tu_usuario
DB_PASSWORD=tu_contraseña
DB_NAME=MariasRestoBar

# Opción B: Railway / otros hosts que entregan una sola URL (tiene prioridad si está definida)
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Si la conexión falla por SSL (p. ej. algunos hosts externos)
# DATABASE_SSL=true

JWT_SECRET=genera_un_secreto_largo_y_unico

# Orígenes permitidos para CORS (separados por coma, sin espacios extra)
# En local se usan valores por defecto si omitís esta variable.
# CORS_ORIGIN=http://localhost:5173,https://tu-frontend.up.railway.app

# Puerto del servidor (Railway inyecta PORT automáticamente)
# PORT=3000
